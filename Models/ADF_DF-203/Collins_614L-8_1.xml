<!--BFO switch-->
 <animation>
  <type>pick</type>
  <object-name>clickspot_adfbfo_up</object-name>
  <visible>false</visible>
  <action>
    <button>0</button>
    <repeatable>false</repeatable>
    <binding>
      <command>nasal</command>
      <script>
	interpolate("Hansajet/ADF/adf1_sw_BFO", 1.0, 0.1 );
      </script>
    </binding>
  </action>
   <hovered>
    <binding>
      <command>set-tooltip</command>
      <tooltip-id>adfbfoon</tooltip-id>
      <label>BFO ON</label>
    </binding>
   </hovered>
 </animation>

 <animation>
  <type>pick</type>
  <object-name>clickspot_adfbfo_down</object-name>
  <visible>false</visible>
  <action>
    <button>0</button>
    <repeatable>false</repeatable>
    <binding>
      <command>nasal</command>
      <script>
	interpolate("Hansajet/ADF/adf1_sw_BFO", 0.0, 0.1 );
      </script>
    </binding>
  </action>
   <hovered>
    <binding>
      <command>set-tooltip</command>
      <tooltip-id>adfbfooff</tooltip-id>
      <label>BFO OFF</label>
    </binding>
   </hovered>
 </animation>

 <animation>
   <type>rotate</type>
   <object-name>sw_BFO</object-name>
   <property>Hansajet/ADF/adf1_sw_BFO</property>
  <interpolation>
    <entry><ind>0.0</ind><dep>15.0</dep></entry>
    <entry><ind>1.0</ind><dep>-15.0</dep></entry>
  </interpolation>
   <center>
    <x-m>-0.002</x-m>
    <y-m>0.0</y-m>
    <z-m>0.022</z-m>
   </center>
   <axis>
    <x>0.0</x>
    <y>1.0</y>
    <z>0.0</z>
   </axis>
 </animation>

<!--Needle Tuning Meter-->
 <animation>
   <type>rotate</type>
   <object-name>needle_TuningMeter</object-name>
   <property>/instrumentation/adf[0]/signal-strength</property>
   <factor>100</factor>
   <offset-deg>-50</offset-deg>
  <center>
    <x-m>0.0</x-m>
    <y-m>0.0416</y-m>
    <z-m>0.016</z-m>
  </center>
  <axis>
    <x>-1</x>
    <y>0</y>
    <z>0</z>
  </axis>
 </animation>

</PropertyList>
