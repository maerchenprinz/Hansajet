<?xml version="1.0"?>

<PropertyList>
 <path>Collins_614L-8.ac</path>

 <animation include="../CockpitShadowAnimation.xml"/>
 <animation include="../CockpitRangeAnimation.xml"/>

<!--Loop knob-->
 <animation>
  <type>pick</type>
  <object-name>clickspot_adfloop_left</object-name>
  <visible>false</visible>
  <action>
   <button>0</button>
   <repeatable>false</repeatable>
   <binding>
    <command>property-interpolate</command>
    <property>/Hansajet/ADF/adf1_Loop</property>
    <value type="double">-2.0</value>
    <rate>2.0</rate>
   </binding>
  <mod-up>
   <binding>
    <command>property-interpolate</command>
    <property>/Hansajet/ADF/adf1_Loop</property>
    <value type="double">0.0</value>
    <rate>10.0</rate>
   </binding>
  </mod-up>
  </action>
  <hovered>
   <binding>
    <command>set-tooltip</command>
    <tooltip-id>adf1loopl</tooltip-id>
    <label>Loop Antenna left</label>
   </binding>
  </hovered>
 </animation>

 <animation>
  <type>pick</type>
  <object-name>clickspot_adfloop_right</object-name>
  <visible>false</visible>
  <action>
   <button>0</button>
   <repeatable>false</repeatable>
   <binding>
    <command>property-interpolate</command>
    <property>/Hansajet/ADF/adf1_Loop</property>
    <value type="double">2.0</value>
    <rate>2.0</rate>
   </binding>
  <mod-up>
   <binding>
    <command>property-interpolate</command>
    <property>/Hansajet/ADF/adf1_Loop</property>
    <value type="double">0.0</value>
    <rate>10.0</rate>
   </binding>
  </mod-up>
  </action>
  <hovered>
   <binding>
    <command>set-tooltip</command>
    <tooltip-id>adf1loopr</tooltip-id>
    <label>Loop Antenna right</label>
   </binding>
  </hovered>
 </animation>

 <animation>
   <type>rotate</type>
   <object-name>kn_Loop</object-name>
   <property>/Hansajet/ADF/adf1_Loop</property>
   <factor>30</factor>
  <center>
    <x-m>0.0</x-m>
    <y-m>-0.048</y-m>
    <z-m>0.018</z-m>
  </center>
  <axis>
    <x>-1</x>
    <y>0</y>
    <z>0</z>
  </axis>
 </animation>

<!--Function knob OFF-Compass-Antenna-Frame-->
 <animation>
   <type>knob</type>
   <object-name>ModeKnob</object-name>
   <property>Hansajet/ADF/adf1_kn_Mode</property>
   <factor>30</factor>
   <offset-deg>-45</offset-deg>
  <center>
   <x-m>0.0</x-m>
   <y-m>-0.041</y-m>
   <z-m>-0.012</z-m>
  </center>
  <axis>
    <x>-1.0</x>
    <y>0.0</y>
    <z>0.0</z>
  </axis>
    <action>
     <binding>
     <command>property-cycle</command>
      <property>Hansajet/ADF/adf1_kn_Mode</property>
      <value type="int">0</value>
      <value type="int">1</value>
      <value type="int">2</value>
      <value type="int">3</value>
      <min>0</min>
      <max>3</max>
      <wrap>false</wrap>
     </binding>
    <binding>
      <command>nasal</command>
      <script>
	var adf1mode = ['off', 'adf', 'ant', 'off'];
	setprop("/instrumentation/adf[0]/mode", adf1mode[getprop("Hansajet/ADF/adf1_kn_Mode")] );
	var adf1refmode = ['off', 'adf', 'off', 'adf'];
	setprop("/instrumentation/adf[1]/mode", adf1refmode[getprop("Hansajet/ADF/adf1_kn_Mode")] );
      </script>
    </binding>
    </action>

   <hovered>
    <binding>
      <command>set-tooltip</command>
      <tooltip-id>adf1-mode</tooltip-id>
      <label>%s</label>
      <property>Hansajet/ADF/adf1_kn_Mode</property>
      <mapping>nasal</mapping>
      <script>
        var adf1mode = ['OFF', 'ADF', 'Antenna', 'Loop'];
        return adf1mode[arg[0]];
      </script>
    </binding>
   </hovered>
 </animation>

<!-- Volume knob -->
 <animation>
   <type>knob</type>
   <object-name>kn_GainControl</object-name>
    <property>Hansajet/ADF/adf1_Volume</property>
   <factor>180</factor>
   <offset-deg>-30</offset-deg>
  <center>
   <x-m>0.0</x-m>
   <y-m>-0.041</y-m>
   <z-m>-0.012</z-m>
  </center>
  <axis>
    <x>-1.0</x>
    <y>0.0</y>
    <z>0.0</z>
  </axis>
    <action>
     <binding>
      <command>property-adjust</command>
      <property>Hansajet/ADF/adf1_Volume</property>
      <factor>0.05</factor>
      <min>0</min>
      <max>1</max>                
      <wrap>false</wrap>
     </binding>
    </action>
   <hovered>
    <binding>
     <command>set-tooltip</command>
      <label>Volume: %3d%%</label>
      <measure-text>Volume: 100%</measure-text>
      <tooltip-id>adf1vol</tooltip-id>
      <mapping>percent</mapping>
      <property>Hansajet/ADF/adf1_Volume</property>
    </binding>
   </hovered>
 </animation>

<!-- Band Knob -->
 <animation>
   <type>knob</type>
   <object-name>kn_Band</object-name>
   <property>Hansajet/ADF/adf1_Subband</property>
    <interpolation>
     <entry><ind>190.0</ind><dep>-45.0</dep></entry>
     <entry><ind>400.0</ind><dep>0.0</dep></entry>
     <entry><ind>840.0</ind><dep>45.0</dep></entry>
    </interpolation>
  <center>
   <x-m>0.0</x-m>
   <y-m>0.0433</y-m>
   <z-m>-0.0143</z-m>
  </center>
  <axis>
    <x>-1.0</x>
    <y>0.0</y>
    <z>0.0</z>
  </axis>
   <action>
    <binding>
     <command>property-cycle</command>
      <property>Hansajet/ADF/adf1_Subband</property>
      <value type="int">190</value>
      <value type="int">400</value>
      <value type="int">840</value>
      <wrap>false</wrap>
    </binding>
   </action>
 </animation>

 <animation>
  <type>translate</type>
  <object-name>DialDrum</object-name>
  <property>Hansajet/ADF/adf1_Subband</property>
    <interpolation>
     <entry><ind>190</ind><dep>0.0</dep></entry>
     <entry><ind>400</ind><dep>0.012</dep></entry>
     <entry><ind>840</ind><dep>0.024</dep></entry>
    </interpolation>
  <axis>
    <x>0</x>
    <y>0</y>
    <z>1</z>
  </axis>
 </animation>

<!-- Tune Knob -->
 <animation>
  <type>knob</type>
  <object-name>kn_Tune</object-name>
   <property>Hansajet/ADF/adf1_TuneKnob</property>
   <factor>4.0</factor>
  <center>
   <x-m>0.0</x-m>
   <y-m>0.0433</y-m>
   <z-m>-0.0143</z-m>
  </center>
  <axis>
    <x>-1.0</x>
    <y>0.0</y>
    <z>0.0</z>
  </axis>
  <action>
  <binding>
   <condition>
    <equals>
     <property>Hansajet/ADF/adf1_Subband</property>
     <value>190</value>
    </equals>
   </condition>
   <command>property-adjust</command>
   <property>Hansajet/ADF/adf1_TuneKnob</property>
   <factor>1.0</factor>
   <min>0.0</min>
   <max>210.0</max>
   <wrap>false</wrap>
  </binding>

  <binding>
   <condition>
    <equals>
     <property>Hansajet/ADF/adf1_Subband</property>
     <value>400</value>
    </equals>
   </condition>
   <command>property-adjust</command>
   <property>Hansajet/ADF/adf1_TuneKnob</property>
   <factor>1.0</factor>
   <min>0.0</min>
   <max>440.0</max>
   <wrap>false</wrap>
  </binding>

  <binding>
   <condition>
    <equals>
     <property>Hansajet/ADF/adf1_Subband</property>
     <value>840</value>
    </equals>
   </condition>
   <command>property-adjust</command>
   <property>Hansajet/ADF/adf1_TuneKnob</property>
   <factor>1.0</factor>
   <min>0.0</min>
   <max>910.0</max>
   <wrap>false</wrap>
  </binding>
  </action>

