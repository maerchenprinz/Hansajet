<?xml version="1.0"?>

<PropertyList>
 <path>audiopanel.ac</path>

 <animation>
  <type>pick</type>
  <object-name>clickspot_audiopanel_uhf_up</object-name>
  <visible>false</visible>
  <action>
    <button>0</button>
    <repeatable>false</repeatable>
    <binding>
      <command>nasal</command>
      <script>
	interpolate("Hansajet/AudioPanel/sw_UHF_0", 1.0, 0.1 );
#	settimer(func {instruments.AudioOutput(Device = "UHF");}, 0.1);
      </script>
    </binding>
  </action>
   <hovered>
    <binding>
      <command>set-tooltip</command>
      <tooltip-id>audiopaneluhfupl</tooltip-id>
      <label>UHF/HF-1 Audible</label>
    </binding>
   </hovered>
 </animation>

