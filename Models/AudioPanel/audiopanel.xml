 <animation>
   <type>rotate</type>
   <object-name>sw_audiopanel_uhf</object-name>
   <property>Hansajet/AudioPanel/sw_UHF_0</property>
  <interpolation>
    <entry><ind>0.0</ind><dep>16.0</dep></entry>
    <entry><ind>1.0</ind><dep>-16.0</dep></entry>
