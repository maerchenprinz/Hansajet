<?xml version="1.0" ?>
<PropertyList>
  <path>Collins-313N-3D.ac</path>

  <animation>
    <type>material</type>
    <object-name>Labels</object-name>
    <object-name>Comm100M</object-name>
    <object-name>Comm10M</object-name>
    <object-name>Comm1M</object-name>
    <object-name>Comm100k</object-name>
    <object-name>Comm10k</object-name>
    <object-name>Comm1k</object-name>
    <object-name>Nav100M</object-name>
    <object-name>Nav10M</object-name>
    <object-name>Nav1M</object-name>
    <object-name>Nav100k</object-name>
    <object-name>Nav10k</object-name>
    <emission include="../InstrumentLightEmissionInclude.xml"/>
  </animation>

  <animation>
    <type>material</type>
    <object-name>Cover</object-name>
    <object-name>Plate</object-name>
    <emission include="../CockpitLightEmissionInclude.xml"/>
  </animation>
    
<!-- Left knob: OFF-PWR-TEST -->
 <animation>
   <type>knob</type>
   <object-name>kn_Comm1Mode</object-name>
    <property>Hansajet/COMM/kn_Comm1_Mode</property>
    <factor>45</factor>
    <center>
     <x-m>0</x-m>
     <y-m>-0.051</y-m>
     <z-m>-0.0178</z-m>
    </center>
    <axis>
     <x>-1</x>
     <y>0</y>
     <z>0</z>
    </axis>
  <action>
   <binding>
    <command>property-adjust</command>
    <property>Hansajet/COMM/kn_Comm1_Mode</property>
     <factor>1</factor>
     <min>0</min>
     <max>2</max>
     <wrap>false</wrap>
     <mask>integer</mask>
   </binding>
  </action>
   <hovered>
    <binding>
      <command>set-tooltip</command>
      <tooltip-id>comm1mode</tooltip-id>
      <label>%s</label>
      <property>Hansajet/COMM/kn_Comm1_Mode</property>
      <mapping>nasal</mapping>
      <script>
        var comm1mode = ['OFF', 'Power', 'Test'];
        return comm1mode[arg[0]];
      </script>
    </binding>
   </hovered>
 </animation>

<!-- Left knob: COMM-MHz -->
 <animation>
   <type>knob</type>
   <object-name>kn_Comm1_MHz</object-name>
    <property>Hansajet/COMM/kn_Comm1_MHz</property>
    <factor>18</factor>
    <center>
     <x-m>0</x-m>
     <y-m>-0.051</y-m>
     <z-m>-0.0178</z-m>
    </center>
    <axis>
     <x>-1</x>
     <y>0</y>
     <z>0</z>
    </axis>
  <action>
   <binding>
    <command>property-adjust</command>
    <property>instrumentation/comm[0]/frequencies/selected-mhz</property>
     <factor>1</factor>
     <min>118.0</min>
     <max>137.0</max>
     <wrap>true</wrap>
     <mask>integer</mask>
   </binding>
   <binding>
    <command>property-adjust</command>
     <property>Hansajet/COMM/kn_Comm1_MHz</property>
     <factor>1.0</factor>
     <min>0.0</min>
     <max>20.0</max>
     <wrap>true</wrap>
   </binding>
  </action>
   <hovered>
    <binding>
      <command>set-tooltip</command>
      <label>COMM-1 %3.3fMHz</label>
      <tooltip-id>comm1freqmhz</tooltip-id>
      <property>instrumentation/comm[0]/frequencies/selected-mhz</property>
    </binding>
   </hovered>
 </animation>

<!-- Right knob: COMM volume -->
 <animation>
   <type>knob</type>
   <object-name>kn_Comm1Vol</object-name>
    <property>Hansajet/COMM/comm1_Volume</property>
    <offset-deg>60.0</offset-deg>
    <factor>180</factor>
  <axis>
    <x>-1.0</x>
    <y>0.0</y>
    <z>0.0</z>
  </axis>
  <center>
   <x-m>0.0</x-m>
   <y-m>-0.015</y-m>
   <z-m>-0.018</z-m>
  </center>
    <action>
     <binding>
      <command>property-adjust</command>
      <property>Hansajet/COMM/comm1_Volume</property>
      <factor>0.05</factor>
      <min>0</min>
      <max>1</max>                
      <wrap>false</wrap>
     </binding>
    </action>
   <hovered>
    <binding>
     <command>set-tooltip</command>
      <label>Volume: %3d%%</label>
      <measure-text>Volume: 100%</measure-text>
      <tooltip-id>comm1vol</tooltip-id>
      <mapping>percent</mapping>
      <property>Hansajet/COMM/comm1_Volume</property>
    </binding>
   </hovered>
 </animation>

<!-- Right knob: COMM-kHz -->
 <animation>
   <type>knob</type>
   <object-name>kn_Comm1_kHz</object-name>
    <property>Hansajet/COMM/kn_Comm1_kHz</property>
    <factor>18</factor>
   <axis>
    <x>-1.0</x>
    <y>0.0</y>
    <z>0.0</z>
   </axis>
   <center>
    <x-m>0.0</x-m>
    <y-m>-0.015</y-m>
    <z-m>-0.018</z-m>
   </center>
  <action>
   <binding>
    <command>property-adjust</command>
     <property>instrumentation/comm[0]/frequencies/selected-mhz</property>
     <factor>0.025</factor>
     <min>0.0</min>
     <max>1.0</max>
     <resolution>0.025</resolution>
     <wrap>true</wrap>
     <mask>decimal</mask>
   </binding>
   <binding>
    <command>property-adjust</command>
     <property>Hansajet/COMM/kn_Comm1_kHz</property>
     <factor>1.0</factor>
     <min>0.0</min>
     <max>40.0</max>
     <wrap>true</wrap>
   </binding>
  </action>
   <hovered>
    <binding>
      <command>set-tooltip</command>
      <label>COMM-1 %3.3fMHz</label>
      <tooltip-id>comm1freq</tooltip-id>
      <property>instrumentation/comm[0]/frequencies/selected-mhz</property>
    </binding>
   </hovered>
 </animation>
    
  <!-- NAV (right half) -->
  <!-- Left knob: OFF-NAV-STBY-DME-OVRD -->
 <animation>
   <type>knob</type>
   <object-name>kn_NAV1Mode</object-name>
    <property>Hansajet/NAV/nav1_kn_Mode</property>
    <factor>40</factor>
    <center>
      <x-m>0</x-m>
      <y-m>0.015</y-m>
      <z-m>-0.0178</z-m>
    </center>
    <axis>
      <x>-1</x>
      <y>0</y>
      <z>0</z>
    </axis>
  <action>
   <binding>
    <command>property-adjust</command>
    <property>Hansajet/NAV/nav1_kn_Mode</property>
     <factor>1</factor>
     <min>0</min>
     <max>4</max>
     <wrap>false</wrap>
     <mask>integer</mask>
   </binding>
  </action>
   <hovered>
    <binding>
      <command>set-tooltip</command>
