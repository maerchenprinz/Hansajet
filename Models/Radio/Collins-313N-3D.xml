      <label>%s</label>
      <property>Hansajet/NAV/nav1_kn_Mode</property>
      <mapping>nasal</mapping>
      <script>
        var nav1mode = ['OFF', 'NAV', 'Standby', 'DME', 'Override'];
        return nav1mode[arg[0]];
