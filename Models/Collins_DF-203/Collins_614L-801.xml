<?xml version="1.0"?>

<PropertyList>
 <path>Collins_614L-801.ac</path>

<!-- Band Knob -->
 <animation>
   <type>knob</type>
   <object-name>BandKnob</object-name>
   <property>Hansajet/ADF/Subband</property>
    <interpolation>
     <entry><ind>190.0</ind><dep>0.0</dep></entry>
     <entry><ind>400.0</ind><dep>30.0</dep></entry>
     <entry><ind>840.0</ind><dep>60.0</dep></entry>
    </interpolation>
  <center>
   <x-m>0.0</x-m>
   <y-m>0.0433</y-m>
   <z-m>-0.0153</z-m>
  </center>
  <axis>
    <x>-1.0</x>
    <y>0.0</y>
    <z>0.0</z>
  </axis>
    <action>
    <binding>
     <command>property-cycle</command>
      <property>Hansajet/ADF/Subband</property>
      <value type="int">0</value>
      <value type="int">1</value>
      <value type="int">2</value>
      <wrap>false</wrap>
      </binding>
    </action>
   <hovered>
    <binding>
      <command>set-tooltip</command>
      <tooltip-id>adf1-subband</tooltip-id>
      <label>%s</label>
      <property>Hansajet/ADF/Subband</property>
      <mapping>nasal</mapping>
      <script>
        var adf1subband = ['190-400kHz', '400-840kHz', '840-1750kHz'];
        return adf1subband[arg[0]];
      </script>
    </binding>
   </hovered>
 </animation>

 <animation>
  <type>translate</type>
  <object-name>DialDrum</object-name>
  <property>Hansajet/ADF/Subband</property>
  <factor>0.012</factor>
  <axis>
    <x>0</x>
    <y>0</y>
    <z>1</z>
  </axis>
 </animation>

<!-- Tune Knob -->
 <animation>
   <type>knob</type>
   <object-name>TuneKnob</object-name>
   <property>Hansajet/ADF/Tune_kHz</property>
    <!--interpolation>
     <entry><ind>190.0</ind><dep>0.0</dep></entry>
     <entry><ind>200.0</ind><dep>30.0</dep></entry>
     <entry><ind>400.0</ind><dep>330.0</dep></entry>
    </interpolation-->
    <interpolation>
     <entry><ind>400.0</ind><dep>0.0</dep></entry>
     <entry><ind>800.0</ind><dep>288.0</dep></entry>
     <entry><ind>840.0</ind><dep>324.0</dep></entry>
    </interpolation>
  <center>
   <x-m>0.0</x-m>
   <y-m>0.0433</y-m>
   <z-m>-0.0153</z-m>
  </center>
  <axis>
    <x>-1.0</x>
    <y>0.0</y>
    <z>0.0</z>
  </axis>
    <action>
     <binding>
      <command>property-adjust</command>
      <property>Hansajet/ADF/Tune_kHz</property>
      <factor>1.0</factor>
      <!--min>190.0</min>
      <max>400.0</max-->
      <min>400.0</min>
      <max>840.0</max>
      <wrap>false</wrap>
     </binding>
    </action>
   <hovered>
    <binding>
     <command>set-tooltip</command>
      <label>Tune Freq
    %4ukHz</label>
      <tooltip-id>ADF_subband1</tooltip-id>
      <property>Hansajet/ADF/Tune_kHz</property>
    </binding>
   </hovered>
 </animation>

 <animation>
  <type>rotate</type>
  <object-name>DialDrum</object-name>
   <property>Hansajet/ADF/Tune_kHz</property>
    <!--interpolation>
     <entry><ind>190.0</ind><dep>0.0</dep></entry>
     <entry><ind>200.0</ind><dep>30.0</dep></entry>
     <entry><ind>400.0</ind><dep>330.0</dep></entry>
    </interpolation-->
    <interpolation>
     <entry><ind>400.0</ind><dep>0.0</dep></entry>
     <entry><ind>800.0</ind><dep>288.0</dep></entry>
     <entry><ind>840.0</ind><dep>324.0</dep></entry>
    </interpolation>
   <center>
    <x-m>-0.0195</x-m>
    <y-m>0.0</y-m>
    <z-m>0.0</z-m>
   </center>
   <axis>
    <x>0.0</x>
    <y>0.0</y>
    <z>-1.0</z>
   </axis>
 </animation>

 <animation>
   <type>rotate</type>
   <object-name>sw_audiopanel_int</object-name>
   <property>Hansajet/AudioPanel/sw_INT</property>
  <interpolation>
    <entry><ind>0.0</ind><dep>16.0</dep></entry>
    <entry><ind>1.0</ind><dep>-16.0</dep></entry>
  </interpolation>
   <center>
    <x-m>-0.026</x-m>
    <y-m>-0.002</y-m>
    <z-m>0.0</z-m>
   </center>
   <axis>
    <x>0.0</x>
    <y>0.0</y>
    <z>1.0</z>
   </axis>
 </animation>

<!--Loop switch-->
 <animation>
   <type>knob</type>
   <object-name>kn_Loop</object-name>
    <property>Hansajet/ADF/Loop</property>
   <factor>40</factor>
  <center>
   <x-m>0.0</x-m>
   <y-m>-0.048</y-m>
   <z-m>0.018</z-m>
  </center>
  <axis>
    <x>-1.0</x>
    <y>0.0</y>
    <z>0.0</z>
  </axis>
    <action>
     <binding>
      <command>property-adjust</command>
      <property>Hansajet/ADF/Loop</property>
      <factor>-1</factor>
      <min>0</min>
      <max>3</max>                
      <wrap>false</wrap>
     </binding>
    </action>
   <!--hovered>
    <binding>
      <command>set-tooltip</command>
      <tooltip-id>ark1-mode</tooltip-id>
      <label>%s</label>
      <property>an24/ARK-11/mode-nav</property>
      <mapping>nasal</mapping>
      <script>
        var ark1mode = ['OFF', 'Compass I', 'Antenna', 'Frame', 'Compass II'];
        return ark1mode[arg[0]];
      </script>
    </binding>
   </hovered-->
 </animation>

<!--Function switch OFF-Compass-Antenna-Frame-->
 <animation>
   <type>knob</type>
   <object-name>ModeKnob</object-name>
    <property>Hansajet/ADF/Mode</property>
   <factor>40</factor>
  <center>
   <x-m>0.0</x-m>
   <y-m>-0.041</y-m>
   <z-m>-0.014</z-m>
  </center>
  <axis>
    <x>-1.0</x>
    <y>0.0</y>
    <z>0.0</z>
  </axis>
    <action>
     <binding>
      <command>property-adjust</command>
      <property>Hansajet/ADF/Mode</property>
      <factor>1</factor>
      <min>0</min>
      <max>3</max>                
      <wrap>false</wrap>
     </binding>
    </action>
   <hovered>
    <binding>
      <command>set-tooltip</command>
      <tooltip-id>adf1-mode</tooltip-id>
      <label>%s</label>
      <property>Hansajet/ADF/Mode</property>
      <mapping>nasal</mapping>
      <script>
        var adf1mode = ['OFF', 'ADF', 'Antenna', 'Loop'];
        return adf1mode[arg[0]];
      </script>
    </binding>
   </hovered>
 </animation>

</PropertyList>
